        "message": "<HeroModelDiagram> doesn't accept that prop. Declared props: models, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|className|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IndustryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|name|className|key|ref|className|style|children)$/]",
        "message": "<IndustryCard> doesn't accept that prop. Declared props: icon, name, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|suffix|mono|className|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, suffix, mono, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogoStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:logos|caption|className|key|ref|className|style|children)$/]",
        "message": "<LogoStrip> doesn't accept that prop. Declared props: logos, caption, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:x|y|label|kind|r|key|ref|className|style|children)$/]",
        "message": "<ModelNode> doesn't accept that prop. Declared props: x, y, label, kind, r."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelNode'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:western|local)$/]",
        "message": "<ModelNode> kind must be one of 'western' | 'local'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrchestratorModel'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|kind|key|ref|className|style|children)$/]",
        "message": "<OrchestratorModel> doesn't accept that prop. Declared props: name, kind."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrchestratorModel'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:western|local)$/]",
        "message": "<OrchestratorModel> kind must be one of 'western' | 'local'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|description|featured|badge|features|cta|onSelect|className|key|ref|className|style|children)$/]",
        "message": "<PricingCard> doesn't accept that prop. Declared props: name, description, featured, badge, features, cta, onSelect, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductWindow'] > JSXAttribute > JSXIdentifier[name!=/^(?:url|children|className|key|ref|className|style|children)$/]",
        "message": "<ProductWindow> doesn't accept that prop. Declared props: url, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScrollReveal'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|delay|y|as|className|style|key|ref|className|style|children)$/]",
        "message": "<ScrollReveal> doesn't accept that prop. Declared props: children, delay, y, as, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScrollStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|bullets|key|ref|className|style|children)$/]",
        "message": "<ScrollStep> doesn't accept that prop. Declared props: icon, title, description, bullets."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|align|className|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: title, subtitle, align, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionHeader> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatMetric'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|className|key|ref|className|style|children)$/]",
        "message": "<StatMetric> doesn't accept that prop. Declared props: value, label, className."
