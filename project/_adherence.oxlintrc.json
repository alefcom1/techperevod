      {
        "selector": "JSXOpeningElement[name.name='StepFlowStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|key|ref|className|style|children)$/]",
        "message": "<StepFlowStep> doesn't accept that prop. Declared props: icon, title, description."
